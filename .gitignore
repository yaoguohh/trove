# === Swift Package Manager ===
.build/
.swiftpm/
# Package.resolved is committed (this is an app, not a library) — do NOT ignore it.

# === Xcode user state (written even without an .xcodeproj when the package is opened in Xcode) ===
xcuserdata/
*.xcuserstate
DerivedData/

# === macOS ===
.DS_Store

# === VS Code — ignore personal/local state (the shared launch.json is already tracked) ===
.vscode/

# === Project-specific ===
.build-cache/
.codegraph/
# Release artifacts — generated by CI / the package script, served from GitHub Releases, never committed.
dist/
appcast.xml
